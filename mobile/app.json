{
  "expo": {
    "name": "HarputKales",
    "slug": "HarputKales",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/harput-castle.png",
    "scheme": "harputkales",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "$(PRODUCT_NAME) would like to read photos for AR experiences.",
        "NSPhotoLibraryAddUsageDescription": "Allow $(PRODUCT_NAME) to save photos",
        "NSCameraUsageDescription": "$(PRODUCT_NAME) uses your camera for AR experiences.",
        "NSMicrophoneUsageDescription": "$(PRODUCT_NAME) uses your microphone for AR experiences."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/harput-castle.png",
        "backgroundImage": "./assets/images/harput-castle.png",
        "monochromeImage": "./assets/images/harput-castle.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.HarputKales"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/harput-castle.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/harput-castle.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-localization",
      [
        "@reactvision/react-viro",
        {
          "android": {
            "xRMode": "AR"
          },
          "ios": {
            "cameraUsagePermission": "$(PRODUCT_NAME) uses your camera for AR experiences.",
            "microphoneUsagePermission": "$(PRODUCT_NAME) uses your microphone for AR experiences.",
            "photosPermission": "$(PRODUCT_NAME) would like to read photos for AR experiences.",
            "savephotosPermission": "$(PRODUCT_NAME) would like to save photos to your library during AR experiences."
          },
          "provider": "none"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
